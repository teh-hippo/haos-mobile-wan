{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>teh-hippo/common-repo-configs//renovate/default.json5"],
  "packageRules": [
    {
      "description": "Runtime base updates require an app version and changelog",
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["ha_cellular_gateway/Dockerfile"],
      "automerge": false
    },
    {
      "description": "Keep validation on the supported Python 3.13 floor",
      "matchPackageNames": ["python"],
      "matchFileNames": [".python-version"],
      "allowedVersions": "3.13"
    }
  ]
}
